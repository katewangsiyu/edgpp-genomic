\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces HCCP vs.\ contemporary local-CP methods on TraitGym CADD+GPN-MSA+Borzoi, sharing the same $(\hat  {p}, \hat  {\sigma })$. Partition $K$ for HCCP / SC-CP selected per outer fold via proper nested chrom-LOO; reporting metric $(y, \hat  {\sigma }\text  {-bin})$-conditional worst-cell gap at fixed $K_{\mathrm  {eval}}$ (Complex $K_{\mathrm  {eval}} = 5$, Mendelian $K_{\mathrm  {eval}} = 3$). $\hat  {\sigma }$-bin gap and $\mathrm  {Cov}_{|Y=1}$ subscripts are $\pm $ one std from $B = 200$ chromosome-level bootstrap resamples. \textbf  {Of the methods we evaluated, HCCP is the only one satisfying both $\mathrm  {cov}_{|Y=1} \geq 0.85$ and $\hat  {\sigma }$-bin gap $\leq 0.20$ on both datasets.} On Complex, HCCP's bootstrap CI for $\hat  {\sigma }$-bin gap is $[0.019, 0.119]$, completely disjoint from baselines' $[0.770, 0.879]$. On Mendelian, the margin tightens: HCCP CI $[0.022, 0.733]$ overlaps with weighted-CP's $[0.141, 0.733]$ at the upper-bound (driven by chromosome-resampling tail), but HCCP's bootstrap mean is $1.5\times $ tighter than weighted CP. RLCP / SC-CP collapse minority coverage on Complex; weighted CP over-covers the minority on Mendelian. Numbers from \texttt  {T\_tools/cp\_baselines\_h2h.py} (point) and \texttt  {T\_tools/bootstrap\_cp\_baselines.py} (bootstrap).}}{16}{table.5}\protected@file@percent }
\newlabel{tab:cp_baselines}{{5}{16}{HCCP vs.\ contemporary local-CP methods on TraitGym CADD+GPN-MSA+Borzoi, sharing the same $(\phat , \shat )$. Partition $K$ for HCCP / SC-CP selected per outer fold via proper nested chrom-LOO; reporting metric $(y, \shat \text {-bin})$-conditional worst-cell gap at fixed $K_{\mathrm {eval}}$ (Complex $K_{\mathrm {eval}} = 5$, Mendelian $K_{\mathrm {eval}} = 3$). $\shat $-bin gap and $\mathrm {Cov}_{|Y=1}$ subscripts are $\pm $ one std from $B = 200$ chromosome-level bootstrap resamples. \textbf {Of the methods we evaluated, HCCP is the only one satisfying both $\mathrm {cov}_{|Y=1} \geq 0.85$ and $\shat $-bin gap $\leq 0.20$ on both datasets.} On Complex, HCCP's bootstrap CI for $\shat $-bin gap is $[0.019, 0.119]$, completely disjoint from baselines' $[0.770, 0.879]$. On Mendelian, the margin tightens: HCCP CI $[0.022, 0.733]$ overlaps with weighted-CP's $[0.141, 0.733]$ at the upper-bound (driven by chromosome-resampling tail), but HCCP's bootstrap mean is $1.5\times $ tighter than weighted CP. RLCP / SC-CP collapse minority coverage on Complex; weighted CP over-covers the minority on Mendelian. Numbers from \texttt {T\_tools/cp\_baselines\_h2h.py} (point) and \texttt {T\_tools/bootstrap\_cp\_baselines.py} (bootstrap)}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Imbalance sweep: $\mathrm  {cov}_{|Y=1}$ as a function of positive-class prevalence $\pi _{+}$, Complex CADD+GPN-MSA+Borzoi. Partition $K$ for B2 / B4 selected per outer fold via nested chrom-LOO at $K_{\mathrm  {eval}} = 5$. B1 and B2 collapse as $\pi _{+} \to 0$; B3 and B4 are insensitive. The right-most column reports HCCP's $\hat  {\sigma }$-bin gap, which stays $\leq 0.07$ across the sweep.}}{16}{table.6}\protected@file@percent }
\newlabel{tab:imbsweep}{{6}{16}{Imbalance sweep: $\mathrm {cov}_{|Y=1}$ as a function of positive-class prevalence $\pi _{+}$, Complex CADD+GPN-MSA+Borzoi. Partition $K$ for B2 / B4 selected per outer fold via nested chrom-LOO at $K_{\mathrm {eval}} = 5$. B1 and B2 collapse as $\pi _{+} \to 0$; B3 and B4 are insensitive. The right-most column reports HCCP's $\shat $-bin gap, which stays $\leq 0.07$ across the sweep}{table.6}{}}
\@writefile{toc}{\contentsline {paragraph}{Imbalance sweep validates T5's $\pi _{\qopname  \relax m{min}}$ dependence.}{16}{section*.38}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.4}Three-axis OOD coverage}{16}{subsection.6.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Complex.} (a) Joint frontier: $\mathrm  {cov}_{|Y=1}$ versus $\hat  {\sigma }$-bin gap, points colored by method, sized by $\pi _{+}$ (Tab.\nobreakspace  {}\ref  {tab:imbsweep}). Lower-right is best. HCCP cluster occupies the high-coverage, low-gap corner alone. (b) $\mathrm  {cov}_{|Y=1}$ versus $\pi _{+}$. Single-axis predictors B1 and B2 collapse as $\pi _{+} \to 0$; HCCP and class-Mondrian (B3) hold at target. T5's $\pi _{\qopname  \relax m{min}}^{-1/2}$ dependence is visible in the divergence of the coloured curves.}}{17}{figure.4}\protected@file@percent }
\newlabel{fig:frontier}{{4}{17}{\textbf {Complex.} (a) Joint frontier: $\mathrm {cov}_{|Y=1}$ versus $\shat $-bin gap, points colored by method, sized by $\pi _{+}$ (Tab.~\ref {tab:imbsweep}). Lower-right is best. HCCP cluster occupies the high-coverage, low-gap corner alone. (b) $\mathrm {cov}_{|Y=1}$ versus $\pi _{+}$. Single-axis predictors B1 and B2 collapse as $\pi _{+} \to 0$; HCCP and class-Mondrian (B3) hold at target. T5's $\pi _{\min }^{-1/2}$ dependence is visible in the divergence of the coloured curves}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Mendelian} companion to Fig.\nobreakspace  {}\ref  {fig:frontier}. (a) Joint frontier: HCCP (B4, red) is again the unique point at $\mathrm  {cov}_{|Y=1} \approx 0.90$ \emph  {and} low $\hat  {\sigma }$-bin gap; B3 (class-Mondrian) holds class coverage but with higher gap; B2 ($\hat  {\sigma }$-Mondrian) under-covers the minority class; B1 (vanilla split) over-covers the minority but at large gap. (b) Imbalance scaling: same qualitative pattern as Complex --- HCCP and B3 hold $\mathrm  {cov}_{|Y=1} \approx 0.90$ across $\pi _{+} \in [0.05, 0.50]$, B2 collapses to $\sim 0.79$ at $\pi _{+} = 0.05$. The two datasets together establish the joint $(y \times \hat  {\sigma }\text  {-bin})$ Mondrian as the only single-fold partition we evaluated that simultaneously satisfies class and bin-local coverage under imbalance.}}{17}{figure.5}\protected@file@percent }
\newlabel{fig:frontier_mendelian}{{5}{17}{\textbf {Mendelian} companion to Fig.~\ref {fig:frontier}. (a) Joint frontier: HCCP (B4, red) is again the unique point at $\mathrm {cov}_{|Y=1} \approx 0.90$ \emph {and} low $\shat $-bin gap; B3 (class-Mondrian) holds class coverage but with higher gap; B2 ($\shat $-Mondrian) under-covers the minority class; B1 (vanilla split) over-covers the minority but at large gap. (b) Imbalance scaling: same qualitative pattern as Complex --- HCCP and B3 hold $\mathrm {cov}_{|Y=1} \approx 0.90$ across $\pi _{+} \in [0.05, 0.50]$, B2 collapses to $\sim 0.79$ at $\pi _{+} = 0.05$. The two datasets together establish the joint $(y \times \shat \text {-bin})$ Mondrian as the only single-fold partition we evaluated that simultaneously satisfies class and bin-local coverage under imbalance}{figure.5}{}}
