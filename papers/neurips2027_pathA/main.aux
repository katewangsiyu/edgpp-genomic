\newlabel{tab:proteingym}{{24}{35}{ProteinGym assay-LOO: HCCP coverage statistics aggregated over the 50 largest valid assays ($\geq 200$ mutants, $\geq 50$ positives; per-assay mutants capped at 3{,}000). $\alpha = 0.10$, $K = 5$. Source: \texttt {outputs/proteingym\_hccp\_n50/summary.json}}{table.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces ProteinGym cross-domain stress test (50 held-out assays). \textbf  {Left:} marginal coverage vs.\ test-assay AUPRC per held-out protein; the 6 under-covering assays (cov $< 0.85$) are coloured red against the 44 in-band assays in grey. Coverage stays within $\pm 0.02$ of the $0.90$ target for $27/50$ assays and within $\pm 0.05$ for $44/50$. AUPRC and coverage are positively correlated (Spearman $\rho = 0.46$, $p = 0.001$): when the base predictor is strong, coverage tracks the target. \textbf  {Right:} distribution of $\hat  {\sigma }$-bin coverage gap across the 50 assays, with the ProteinGym assay mean ($\approx 0.052$) and the TraitGym chrom-LOO cell-level worst-$(k,b)$ reference ($0.077$, Tab.\nobreakspace  {}\ref  {tab:cp_baselines}) overlaid. The ProteinGym distribution sits at roughly the same scale as TraitGym chrom-LOO (median $0.042$, p90 $0.095$), consistent with a genuine but bounded cross-domain shift.}}{35}{figure.8}\protected@file@percent }
\newlabel{fig:proteingym}{{8}{35}{ProteinGym cross-domain stress test (50 held-out assays). \textbf {Left:} marginal coverage vs.\ test-assay AUPRC per held-out protein; the 6 under-covering assays (cov $< 0.85$) are coloured red against the 44 in-band assays in grey. Coverage stays within $\pm 0.02$ of the $0.90$ target for $27/50$ assays and within $\pm 0.05$ for $44/50$. AUPRC and coverage are positively correlated (Spearman $\rho = 0.46$, $p = 0.001$): when the base predictor is strong, coverage tracks the target. \textbf {Right:} distribution of $\shat $-bin coverage gap across the 50 assays, with the ProteinGym assay mean ($\approx 0.052$) and the TraitGym chrom-LOO cell-level worst-$(k,b)$ reference ($0.077$, Tab.~\ref {tab:cp_baselines}) overlaid. The ProteinGym distribution sits at roughly the same scale as TraitGym chrom-LOO (median $0.042$, p90 $0.095$), consistent with a genuine but bounded cross-domain shift}{figure.8}{}}
