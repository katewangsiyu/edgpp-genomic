\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces HCCP vs.\ contemporary local-CP methods on TraitGym CADD+GPN-MSA+Borzoi at $K = \hat  K_{\mathrm  {CV}}$, sharing the same $(\hat  {p}, \hat  {\sigma })$. \textbf  {HCCP is the unique method achieving both $\mathrm  {cov}_{|Y=1} \geq 0.89$ and $\hat  {\sigma }$-bin gap $\leq 0.10$ on either dataset.} RLCP/SC-CP collapse minority coverage on Complex (under-covering pathogenic class), and all three baselines have $\hat  {\sigma }$-bin gap $\geq 0.19$. Singleton fractions in column 6 reflect the trade-off: RLCP/SC-CP achieve high singleton rates by giving up minority coverage. Numbers from \texttt  {T\_tools/cp\_baselines\_h2h.py} (single seed, full chrom-LOO).}}{14}{table.5}\protected@file@percent }
\newlabel{tab:cp_baselines}{{5}{14}{HCCP vs.\ contemporary local-CP methods on TraitGym CADD+GPN-MSA+Borzoi at $K = \hat K_{\mathrm {CV}}$, sharing the same $(\phat , \shat )$. \textbf {HCCP is the unique method achieving both $\mathrm {cov}_{|Y=1} \geq 0.89$ and $\shat $-bin gap $\leq 0.10$ on either dataset.} RLCP/SC-CP collapse minority coverage on Complex (under-covering pathogenic class), and all three baselines have $\shat $-bin gap $\geq 0.19$. Singleton fractions in column 6 reflect the trade-off: RLCP/SC-CP achieve high singleton rates by giving up minority coverage. Numbers from \texttt {T\_tools/cp\_baselines\_h2h.py} (single seed, full chrom-LOO)}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Imbalance sweep: $\mathrm  {cov}_{|Y=1}$ as a function of positive-class prevalence $\pi _{+}$, fixed $K = 2$, Complex CADD+GPN-MSA+Borzoi. B1 and B2 collapse as $\pi _{+} \to 0$; B3 and B4 are insensitive. The right-most column reports HCCP's $\hat  {\sigma }$-bin gap, which stays $\leq 0.22$ across the sweep.}}{14}{table.6}\protected@file@percent }
\newlabel{tab:imbsweep}{{6}{14}{Imbalance sweep: $\mathrm {cov}_{|Y=1}$ as a function of positive-class prevalence $\pi _{+}$, fixed $K = 2$, Complex CADD+GPN-MSA+Borzoi. B1 and B2 collapse as $\pi _{+} \to 0$; B3 and B4 are insensitive. The right-most column reports HCCP's $\shat $-bin gap, which stays $\leq 0.22$ across the sweep}{table.6}{}}
