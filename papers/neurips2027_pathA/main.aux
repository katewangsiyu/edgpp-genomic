\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Main results on TraitGym chrom-LOO. AUPRC is weighted by test-chrom size (TraitGym convention). $\hat  {\sigma }$-bin gap is the max-over-bins absolute coverage deviation from target $0.90$. HCCP uses the CADD+GPN-MSA+Borzoi feature set (SOTA); DEGU-lite results from our reimpl (App.\nobreakspace  {}\ref  {app:data}). HCCP row subscripts are $\pm $ one std from $B = 200$ chromosome-level bootstrap resamples; the reported $\hat  {\sigma }$-bin gap is the bootstrap-mean of the per-resample max-over-bins deviation. Non-HCCP rows and the corresponding all-chrom point estimates in Table\nobreakspace  {}\ref  {tab:threeaxis} are computed without resampling and are generally larger when a few chromosomes drive the maximum (e.g., Mendelian CADD+GPN-MSA+Borzoi: bootstrap-mean $0.020 \pm 0.012$ here vs all-chrom point $0.077$ in Table\nobreakspace  {}\ref  {tab:threeaxis}). HCCP rows use $K = 5$ for direct comparability with prior split-CP and class-conditional baselines that share this default; at the cross-validated $\hat  K_{\mathrm  {CV}} = 3$ (Mendelian) / $2$ (Complex), single-seed worst-cell gaps tighten to $0.047$ / $0.006$ respectively (Table\nobreakspace  {}\ref  {tab:ksweep}, App.\nobreakspace  {}\ref  {app:tables:ksweep}), a $6$–$7\times $ improvement over $K = 5$ on the matched single-seed comparison.}}{12}{table.3}\protected@file@percent }
\newlabel{tab:main}{{3}{12}{Main results on TraitGym chrom-LOO. AUPRC is weighted by test-chrom size (TraitGym convention). $\shat $-bin gap is the max-over-bins absolute coverage deviation from target $0.90$. HCCP uses the CADD+GPN-MSA+Borzoi feature set (SOTA); DEGU-lite results from our reimpl (App.~\ref {app:data}). HCCP row subscripts are $\pm $ one std from $B = 200$ chromosome-level bootstrap resamples; the reported $\shat $-bin gap is the bootstrap-mean of the per-resample max-over-bins deviation. Non-HCCP rows and the corresponding all-chrom point estimates in Table~\ref {tab:threeaxis} are computed without resampling and are generally larger when a few chromosomes drive the maximum (e.g., Mendelian CADD+GPN-MSA+Borzoi: bootstrap-mean $0.020 \pm 0.012$ here vs all-chrom point $0.077$ in Table~\ref {tab:threeaxis}). HCCP rows use $K = 5$ for direct comparability with prior split-CP and class-conditional baselines that share this default; at the cross-validated $\hat K_{\mathrm {CV}} = 3$ (Mendelian) / $2$ (Complex), single-seed worst-cell gaps tighten to $0.047$ / $0.006$ respectively (Table~\ref {tab:ksweep}, App.~\ref {app:tables:ksweep}), a $6$–$7\times $ improvement over $K = 5$ on the matched single-seed comparison}{table.3}{}}
