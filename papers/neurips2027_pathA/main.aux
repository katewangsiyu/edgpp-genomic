\@writefile{toc}{\contentsline {paragraph}{Interpretation.}{28}{section*.35}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces HCCP vs DEGU-lite on the (efficiency, $\hat  {\sigma }$-bin coverage gap) Pareto plane. X-axis: singleton fraction (variants receiving a confident $\{0\}$ or $\{1\}$ set rather than the abstention $\{0,1\}$); higher is more efficient. Y-axis: worst $\hat  {\sigma }$-bin coverage gap (lower is better). The shaded \emph  {ideal zone} marks the top-right corner of the plane (high efficiency + low gap). On \textbf  {Complex}, HCCP sits in the ideal zone with $\sim 4\times $ smaller gap than DEGU-lite at matched efficiency, confirming the aleatoric-dominated regime favours supervised $\hat  {\sigma }$. On \textbf  {Mendelian}, DEGU is marginally below HCCP (0.033 vs.\ 0.041), consistent with monogenic signal making ensemble disagreement a near-equivalent proxy. Both methods avoid the high-gap, low-efficiency corner that homoscedastic split-CP and class-Mondrian baselines occupy in Tab.\nobreakspace  {}\ref  {tab:h2h} and Tab.\nobreakspace  {}\ref  {tab:cp_baselines}.}}{29}{figure.5}\protected@file@percent }
\newlabel{fig:pareto_degu}{{5}{29}{HCCP vs DEGU-lite on the (efficiency, $\shat $-bin coverage gap) Pareto plane. X-axis: singleton fraction (variants receiving a confident $\{0\}$ or $\{1\}$ set rather than the abstention $\{0,1\}$); higher is more efficient. Y-axis: worst $\shat $-bin coverage gap (lower is better). The shaded \emph {ideal zone} marks the top-right corner of the plane (high efficiency + low gap). On \textbf {Complex}, HCCP sits in the ideal zone with $\sim 4\times $ smaller gap than DEGU-lite at matched efficiency, confirming the aleatoric-dominated regime favours supervised $\shat $. On \textbf {Mendelian}, DEGU is marginally below HCCP (0.033 vs.\ 0.041), consistent with monogenic signal making ensemble disagreement a near-equivalent proxy. Both methods avoid the high-gap, low-efficiency corner that homoscedastic split-CP and class-Mondrian baselines occupy in Tab.~\ref {tab:h2h} and Tab.~\ref {tab:cp_baselines}}{figure.5}{}}
