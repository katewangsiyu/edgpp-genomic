\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {A-SL audit.} Each subfigure shows (a) per-pair Lipschitz ratio histogram with median, p95, p99, max, and the LCLS least-squares slope $\hat  L_F$ overlay; (b) raw KS vs $\sigma $-gap scatter, LCLS slope (green), and noise-adjusted p95 upper envelope $L_F^{(95\%)}$ (purple). On Mendelian (left, $n=3380$) the upper envelope is wider because KS sampling noise dominates small bins; on Complex (right, $n=11400$) noise contracts, exposing a tighter envelope $L_F^{(95\%)}=8.1$. In both cases the noise-adjusted distribution has finite, bounded support, supporting \ref  {ass:ASL}.}}{6}{figure.2}\protected@file@percent }
\newlabel{fig:asl_audit}{{2}{6}{\textbf {A-SL audit.} Each subfigure shows (a) per-pair Lipschitz ratio histogram with median, p95, p99, max, and the LCLS least-squares slope $\hat L_F$ overlay; (b) raw KS vs $\sigma $-gap scatter, LCLS slope (green), and noise-adjusted p95 upper envelope $L_F^{(95\%)}$ (purple). On Mendelian (left, $n=3380$) the upper envelope is wider because KS sampling noise dominates small bins; on Complex (right, $n=11400$) noise contracts, exposing a tighter envelope $L_F^{(95\%)}=8.1$. In both cases the noise-adjusted distribution has finite, bounded support, supporting \ref {ass:ASL}}{figure.2}{}}
