\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Head-to-head against off-the-shelf normalized + Mondrian CP, sharing the same $(\hat  {p}, \hat  {\sigma })$. Baselines: B2 \citep  {bostrom2020mondrian}, B3 \citep  {sadinle2019lac}. Partition $K$ for B2 / B4 selected per outer fold via proper nested chrom-LOO with $K_{\mathrm  {eval}}$-fair scoring (Mendelian $K_{\mathrm  {eval}} = 3$, Complex $K_{\mathrm  {eval}} = 5$). \textbf  {All four rows on $B = 200$ chromosome-level bootstrap (mean $\pm $ std).} The reported $\hat  {\sigma }$-bin gap is the cell-level worst-$(k,b)$ deviation from $0.90$, the same object as $G(K)$ in Eq.\nobreakspace  {}\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:gap_decomp}\unskip \@@italiccorr )}}; this differs from the marginal-bin metric of Tab.\nobreakspace  {}\ref  {tab:main}. Of the four variants we evaluated, HCCP is the only frontier point at this corner on both datasets. Note that the on-axis baseline B2 $\hat  {\sigma }$-Mondrian still loses on $\hat  {\sigma }$-bin gap because $\hat  {\sigma }$-only stratification does not preserve $\mathrm  {cov}_{|Y=1}$ at $\pi _{\qopname  \relax m{min}}=0.10$; the $(y \times \hat  {\sigma })$ product is necessary, not just the $\hat  {\sigma }$ axis.}}{23}{table.8}\protected@file@percent }
\newlabel{tab:h2h}{{8}{23}{Head-to-head against off-the-shelf normalized + Mondrian CP, sharing the same $(\phat , \shat )$. Baselines: B2 \citep {bostrom2020mondrian}, B3 \citep {sadinle2019lac}. Partition $K$ for B2 / B4 selected per outer fold via proper nested chrom-LOO with $K_{\mathrm {eval}}$-fair scoring (Mendelian $K_{\mathrm {eval}} = 3$, Complex $K_{\mathrm {eval}} = 5$). \textbf {All four rows on $B = 200$ chromosome-level bootstrap (mean $\pm $ std).} The reported $\shat $-bin gap is the cell-level worst-$(k,b)$ deviation from $0.90$, the same object as $G(K)$ in Eq.~\eqref {eq:gap_decomp}; this differs from the marginal-bin metric of Tab.~\ref {tab:main}. Of the four variants we evaluated, HCCP is the only frontier point at this corner on both datasets. Note that the on-axis baseline B2 $\shat $-Mondrian still loses on $\shat $-bin gap because $\shat $-only stratification does not preserve $\mathrm {cov}_{|Y=1}$ at $\pi _{\min }=0.10$; the $(y \times \shat )$ product is necessary, not just the $\shat $ axis}{table.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces HCCP vs.\ contemporary local-CP methods, sharing $(\hat  {p}, \hat  {\sigma })$. Baselines: RLCP \citep  {hore2025rlcp}, weighted CP \citep  {tibshirani2019weighted}, SC-CP \citep  {vanderlaan2024sccp}. $\hat  {\sigma }$-bin gap is the cell-level worst-$(k,b)$ metric (matched to Tab.\nobreakspace  {}\ref  {tab:h2h} convention). Subscripts are $\pm $ one std from $B = 200$ chrom-level bootstrap resamples. Complex CI: HCCP $[0.019, 0.119]$ vs.\ baselines $[0.770, 0.879]$ (disjoint).}}{23}{table.9}\protected@file@percent }
\newlabel{tab:cp_baselines}{{9}{23}{HCCP vs.\ contemporary local-CP methods, sharing $(\phat , \shat )$. Baselines: RLCP \citep {hore2025rlcp}, weighted CP \citep {tibshirani2019weighted}, SC-CP \citep {vanderlaan2024sccp}. $\shat $-bin gap is the cell-level worst-$(k,b)$ metric (matched to Tab.~\ref {tab:h2h} convention). Subscripts are $\pm $ one std from $B = 200$ chrom-level bootstrap resamples. Complex CI: HCCP $[0.019, 0.119]$ vs.\ baselines $[0.770, 0.879]$ (disjoint)}{table.9}{}}
