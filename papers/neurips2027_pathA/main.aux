\@writefile{lot}{\contentsline {table}{\numberline {17}{\ignorespaces $K$-sweep on Mendelian and Complex (CADD+GPN-MSA+Borzoi, $\alpha = 0.10$, single seed, legacy non-nested K-selection). Worst-cell gap = $\qopname  \relax m{max}_{k,b} |\mathrm  {cov}_{k,b} - 0.90|$ on the test fold; $n_{\qopname  \relax m{min}}$ = minimum calibration count per cell; fallback = cells triggering pooled backoff. Bolded rows are the legacy minimum (test-fold leakage; superseded by nested-CV $\hat  K(c_{\mathrm  {outer}})$ in §\ref  {sec:theory:t5} and Tab.\nobreakspace  {}\ref  {tab:LF_estimators}). Single-seed values here are smaller than the bootstrap means in Tab.\nobreakspace  {}\ref  {tab:cp_baselines} because they ride the favourable test fold the legacy selector tunes against.}}{27}{table.17}\protected@file@percent }
\newlabel{tab:ksweep}{{17}{27}{$K$-sweep on Mendelian and Complex (CADD+GPN-MSA+Borzoi, $\alpha = 0.10$, single seed, legacy non-nested K-selection). Worst-cell gap = $\max _{k,b} |\mathrm {cov}_{k,b} - 0.90|$ on the test fold; $n_{\min }$ = minimum calibration count per cell; fallback = cells triggering pooled backoff. Bolded rows are the legacy minimum (test-fold leakage; superseded by nested-CV $\hat K(c_{\mathrm {outer}})$ in §\ref {sec:theory:t5} and Tab.~\ref {tab:LF_estimators}). Single-seed values here are smaller than the bootstrap means in Tab.~\ref {tab:cp_baselines} because they ride the favourable test fold the legacy selector tunes against}{table.17}{}}
\@writefile{lot}{\contentsline {table}{\numberline {18}{\ignorespaces Four $L_F$ estimators and their oracle $K^\star = \lfloor \sqrt  {L_F R \pi _{\qopname  \relax m{min}} n}\rfloor $ and $G(K^\star ) \leq 2\sqrt  {L_F R / (\pi _{\qopname  \relax m{min}} n)}$ bounds. The modal nested-CV $\hat  K(c_{\mathrm  {outer}})$ (§\ref  {sec:theory:t5}) is reported for comparison; the legacy non-nested $K_{\mathrm  {CV}}$ (test-gap argmin) values $3$ Mendelian and $2$ Complex are deprecated.}}{27}{table.18}\protected@file@percent }
\newlabel{tab:LF_estimators}{{18}{27}{Four $L_F$ estimators and their oracle $K^\star = \lfloor \sqrt {L_F R \pi _{\min } n}\rfloor $ and $G(K^\star ) \leq 2\sqrt {L_F R / (\pi _{\min } n)}$ bounds. The modal nested-CV $\hat K(c_{\mathrm {outer}})$ (§\ref {sec:theory:t5}) is reported for comparison; the legacy non-nested $K_{\mathrm {CV}}$ (test-gap argmin) values $3$ Mendelian and $2$ Complex are deprecated}{table.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces $L_F$ estimator 95\% bootstrap CIs and resulting $K^\star $. LCLS gives a tight CI ($\hat  L_F \approx 3$ Mendelian, $\approx 4.5$ Complex) and a realisable $K^\star $ (22 / 50). Isotonic envelope is loose. Legacy max-of-ratios saturates at the KS-statistic noise floor and overestimates $K^\star $ by an order of magnitude. The modal nested-CV $\hat  K(c_{\mathrm  {outer}}) \in \{5, 8\}$ (Mendelian) and $5$ (Complex) is the binding finite-sample constraint, well below all three asymptotic $K^\star $ predictions.}}{28}{figure.3}\protected@file@percent }
\newlabel{fig:lf_forest}{{3}{28}{$L_F$ estimator 95\% bootstrap CIs and resulting $K^\star $. LCLS gives a tight CI ($\hat L_F \approx 3$ Mendelian, $\approx 4.5$ Complex) and a realisable $K^\star $ (22 / 50). Isotonic envelope is loose. Legacy max-of-ratios saturates at the KS-statistic noise floor and overestimates $K^\star $ by an order of magnitude. The modal nested-CV $\hat K(c_{\mathrm {outer}}) \in \{5, 8\}$ (Mendelian) and $5$ (Complex) is the binding finite-sample constraint, well below all three asymptotic $K^\star $ predictions}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Bootstrap distribution of HCCP marginal-bin $\hat  {\sigma }$-bin gap (Tab.\nobreakspace  {}\ref  {tab:main} metric) across $B = 200$ chromosome-level resamples. Mendelian (left) shows substantial right-skew driven by replicates that include high-gap chromosomes (chr6, chr19, chr9, see Tab.\nobreakspace  {}\ref  {tab:perchrom}); the single-seed all-chrom point estimate $0.041$ (Tab.\nobreakspace  {}\ref  {tab:degu}) sits to the right of the bootstrap mean $0.020$. Complex (right) is much tighter (point and bootstrap mean both $\approx 0.02$).}}{28}{figure.4}\protected@file@percent }
\newlabel{fig:bootstrap_density}{{4}{28}{Bootstrap distribution of HCCP marginal-bin $\shat $-bin gap (Tab.~\ref {tab:main} metric) across $B = 200$ chromosome-level resamples. Mendelian (left) shows substantial right-skew driven by replicates that include high-gap chromosomes (chr6, chr19, chr9, see Tab.~\ref {tab:perchrom}); the single-seed all-chrom point estimate $0.041$ (Tab.~\ref {tab:degu}) sits to the right of the bootstrap mean $0.020$. Complex (right) is much tighter (point and bootstrap mean both $\approx 0.02$)}{figure.4}{}}
