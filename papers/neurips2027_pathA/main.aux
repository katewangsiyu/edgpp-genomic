\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Synthetic $n$-sweep validating the $O(n^{-1/2})$ rate of Theorem\nobreakspace  {}\ref  {thm:t5oracle}. Worst-cell gap $G(\hat  K_{\mathrm  {CV}})$ vs calibration size $n$ on log-log axes, split by $\pi _{\qopname  \relax m{min}}$ (left $0.10$, right $0.50$); three coloured curves per panel cover feature dimensions $d \in \{8, 32, 128\}$ with $\pm 1$ SE bars over 5 replicates. Y-axes are shared, so the $\pi _{\qopname  \relax m{min}}^{-1/2}$ vertical offset is visible at a glance: left-panel curves sit roughly $\bar  C_{0.10}/\bar  C_{0.50} = 1.62 \times $ above the right-panel curves at matched $n$, below the T5.1 asymptotic upper-bound ratio $\sqrt  {5} \approx 2.24$ (T5.1 is an upper bound on $G$, so empirical ratios below $\sqrt  {5}$ are consistent with the bound). Black dashed reference: $G = \bar  C(\pi _{\qopname  \relax m{min}}) / \sqrt  {n}$ where $\bar  C(\pi _{\qopname  \relax m{min}})$ is the empirical compensated mean $G(n)\cdot \sqrt  {n}$ averaged over $n \geq 1{,}000$ and $d$ within each panel; this descriptive reference shows where the empirical $-1/2$ slope passes. Per-panel slope fits annotated in upper-right boxes; cross-panel summary in the title gives slope $-0.44 \pm 0.08$ (mean $\pm $ std over 6 fits), with T5.1 prediction $-0.50$ within $1$ standard deviation. Gray bands flag the $n < 1{,}000$ small-sample fallback regime excluded from the fit. The dimension-free claim is visible as overlapping $d$-curves within each panel.}}{38}{figure.9}\protected@file@percent }
\newlabel{fig:n_sweep}{{9}{38}{Synthetic $n$-sweep validating the $O(n^{-1/2})$ rate of Theorem~\ref {thm:t5oracle}. Worst-cell gap $G(\hat K_{\mathrm {CV}})$ vs calibration size $n$ on log-log axes, split by $\pi _{\min }$ (left $0.10$, right $0.50$); three coloured curves per panel cover feature dimensions $d \in \{8, 32, 128\}$ with $\pm 1$ SE bars over 5 replicates. Y-axes are shared, so the $\pi _{\min }^{-1/2}$ vertical offset is visible at a glance: left-panel curves sit roughly $\bar C_{0.10}/\bar C_{0.50} = 1.62 \times $ above the right-panel curves at matched $n$, below the T5.1 asymptotic upper-bound ratio $\sqrt {5} \approx 2.24$ (T5.1 is an upper bound on $G$, so empirical ratios below $\sqrt {5}$ are consistent with the bound). Black dashed reference: $G = \bar C(\pi _{\min }) / \sqrt {n}$ where $\bar C(\pi _{\min })$ is the empirical compensated mean $G(n)\cdot \sqrt {n}$ averaged over $n \geq 1{,}000$ and $d$ within each panel; this descriptive reference shows where the empirical $-1/2$ slope passes. Per-panel slope fits annotated in upper-right boxes; cross-panel summary in the title gives slope $-0.44 \pm 0.08$ (mean $\pm $ std over 6 fits), with T5.1 prediction $-0.50$ within $1$ standard deviation. Gray bands flag the $n < 1{,}000$ small-sample fallback regime excluded from the fit. The dimension-free claim is visible as overlapping $d$-curves within each panel}{figure.9}{}}
\@writefile{toc}{\contentsline {paragraph}{Headline H2H result.}{38}{section*.47}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {27}{\ignorespaces Open Targets matched\_9 H2H, $K_{\mathrm  {eval}} = 5$, $\alpha = 0.10$. HCCP partition $K_{\mathrm  {HCCP}}$ selected per outer fold by nested chrom-LOO. Paired bootstrap on $B = 200$ chrom-resamples (seed 42); win\,\% counts resamples on which HCCP attained a strictly smaller $\hat  {\sigma }$-bin gap than the baseline. The three baselines all hit $\hat  {\sigma }$-bin gap $0.900$, the worst-cell maximum-deviation ceiling (one minority cell at near-zero coverage); the $16.7\times $ ratio is therefore better read as ``HCCP holds the gap floor while the baselines saturate the ceiling'' than as a multiplicative effect-size claim — the binding signal is the absolute gap of $0.054$ vs.\ $0.900$ on the worst cell, plus the $93\%$ paired-resample win rate. Source: \texttt  {R\_raw/cp\_baselines\_h2h/open\_targets\_*.json}.}}{38}{table.27}\protected@file@percent }
\newlabel{tab:open_targets_h2h}{{27}{38}{Open Targets matched\_9 H2H, $K_{\mathrm {eval}} = 5$, $\alpha = 0.10$. HCCP partition $K_{\mathrm {HCCP}}$ selected per outer fold by nested chrom-LOO. Paired bootstrap on $B = 200$ chrom-resamples (seed 42); win\,\% counts resamples on which HCCP attained a strictly smaller $\shat $-bin gap than the baseline. The three baselines all hit $\shat $-bin gap $0.900$, the worst-cell maximum-deviation ceiling (one minority cell at near-zero coverage); the $16.7\times $ ratio is therefore better read as ``HCCP holds the gap floor while the baselines saturate the ceiling'' than as a multiplicative effect-size claim — the binding signal is the absolute gap of $0.054$ vs.\ $0.900$ on the worst cell, plus the $93\%$ paired-resample win rate. Source: \texttt {R\_raw/cp\_baselines\_h2h/open\_targets\_*.json}}{table.27}{}}
\@writefile{toc}{\contentsline {paragraph}{$K_{\mathrm  {eval}}$ reversal replicates the TraitGym Mendelian boundary.}{39}{section*.48}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {28}{\ignorespaces $K_{\mathrm  {eval}}$ sensitivity on Open Targets matched\_9. ``HCCP win ratio'' is best-baseline $\hat  {\sigma }$-bin gap divided by HCCP's; values $> 1$ favour HCCP. Per-cell minority $= \pi _{+} n / K_{\mathrm  {eval}}$ with $\pi _{+} = 0.10$, $n = 11{,}400$. The $K_{\mathrm  {eval}} = 3$ row reflects a $K_{\mathrm  {HCCP}} \neq  K_{\mathrm  {eval}}$ partition--metric mismatch (see text); all other rows have $K_{\mathrm  {HCCP}}$ modal $\in \{5, 8, 10\}$ aligned with $K_{\mathrm  {eval}}$. Excluding the $K_{\mathrm  {eval}} = 3$ mismatch row, the win ratio is monotone non-increasing in $K_{\mathrm  {eval}}$ (equivalently, in per-cell minority count), tracking the variance-term scaling.}}{39}{table.28}\protected@file@percent }
\newlabel{tab:open_targets_keval}{{28}{39}{$K_{\mathrm {eval}}$ sensitivity on Open Targets matched\_9. ``HCCP win ratio'' is best-baseline $\shat $-bin gap divided by HCCP's; values $> 1$ favour HCCP. Per-cell minority $= \pi _{+} n / K_{\mathrm {eval}}$ with $\pi _{+} = 0.10$, $n = 11{,}400$. The $K_{\mathrm {eval}} = 3$ row reflects a $K_{\mathrm {HCCP}} \neq K_{\mathrm {eval}}$ partition--metric mismatch (see text); all other rows have $K_{\mathrm {HCCP}}$ modal $\in \{5, 8, 10\}$ aligned with $K_{\mathrm {eval}}$. Excluding the $K_{\mathrm {eval}} = 3$ mismatch row, the win ratio is monotone non-increasing in $K_{\mathrm {eval}}$ (equivalently, in per-cell minority count), tracking the variance-term scaling}{table.28}{}}
