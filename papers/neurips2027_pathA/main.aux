\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces HCCP $\hat  {\sigma }$-bin gap across three OOD axes (log scale). Trait-LOO reaches the finite-sample $1/(n_{k,b}+1)$ floor on both datasets ($\leq 0.004$); chrom-LOO Complex stays $\leq 0.023$; chrom-LOO Mendelian is $0.077$ on the SOTA feature set; cross-dataset is shown for the C$\to $M direction only (in-bound at $0.036$). The reverse M$\to $C direction is reported separately in §\ref  {sec:experiments:failure_mode} as a diagnostic case study, not summarised here.}}{18}{figure.6}\protected@file@percent }
\newlabel{fig:three_axis}{{6}{18}{HCCP $\shat $-bin gap across three OOD axes (log scale). Trait-LOO reaches the finite-sample $1/(n_{k,b}+1)$ floor on both datasets ($\leq 0.004$); chrom-LOO Complex stays $\leq 0.023$; chrom-LOO Mendelian is $0.077$ on the SOTA feature set; cross-dataset is shown for the C$\to $M direction only (in-bound at $0.036$). The reverse M$\to $C direction is reported separately in §\ref {sec:experiments:failure_mode} as a diagnostic case study, not summarised here}{figure.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Three-axis OOD evaluation of HCCP. Trait-LOO rotates the held-out trait/OMIM (30 Mendelian OMIMs, 28 Complex traits with $\geq 10$ positives). Cross-dataset trains on one dataset and tests on the other. All numbers at $\alpha = 0.10$, $K = 5$ (chosen for direct comparability with the baselines in Table\nobreakspace  {}\ref  {tab:main}); per-outer-fold nested-CV $\hat  K(c_{\mathrm  {outer}})$ with $K_{\mathrm  {eval}}$-fair scoring is reported in Tables\nobreakspace  {}\ref  {tab:h2h} and \ref  {tab:cp_baselines} (App.\nobreakspace  {}\ref  {app:tables:ksweep}). Trait-LOO already reaches the finite-sample $1/(n_{k,b}+1)$ floor at $K = 5$.}}{18}{table.7}\protected@file@percent }
\newlabel{tab:threeaxis}{{7}{18}{Three-axis OOD evaluation of HCCP. Trait-LOO rotates the held-out trait/OMIM (30 Mendelian OMIMs, 28 Complex traits with $\geq 10$ positives). Cross-dataset trains on one dataset and tests on the other. All numbers at $\alpha = 0.10$, $K = 5$ (chosen for direct comparability with the baselines in Table~\ref {tab:main}); per-outer-fold nested-CV $\hat K(c_{\mathrm {outer}})$ with $K_{\mathrm {eval}}$-fair scoring is reported in Tables~\ref {tab:h2h} and \ref {tab:cp_baselines} (App.~\ref {app:tables:ksweep}). Trait-LOO already reaches the finite-sample $1/(n_{k,b}+1)$ floor at $K = 5$}{table.7}{}}
