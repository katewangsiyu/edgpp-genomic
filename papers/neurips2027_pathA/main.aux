\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {A-SL audit.} Per-pair Lipschitz ratio $\rho _{k,a,b} = \mathrm  {KS}(\hat  F_{k,a}, \hat  F_{k,b}) / |\bar  \sigma _a - \bar  \sigma _b|$ on $\hat  {\sigma }$-bin pairs. Noise-adjusted upper envelope is finite without fat-tail breakdown: $L_F^{(95\%)} = 13.8$ (Mendelian) / $8.1$ (Complex). LCLS estimator $\hat  L_F \approx 3$/$4.5$ measures the typical local slope and underestimates the upper envelope by $\sim $3--5$\times $.}}{34}{figure.6}\protected@file@percent }
\newlabel{fig:asl_audit}{{6}{34}{\textbf {A-SL audit.} Per-pair Lipschitz ratio $\rho _{k,a,b} = \mathrm {KS}(\hat F_{k,a}, \hat F_{k,b}) / |\bar \sigma _a - \bar \sigma _b|$ on $\shat $-bin pairs. Noise-adjusted upper envelope is finite without fat-tail breakdown: $L_F^{(95\%)} = 13.8$ (Mendelian) / $8.1$ (Complex). LCLS estimator $\hat L_F \approx 3$/$4.5$ measures the typical local slope and underestimates the upper envelope by $\sim $3--5$\times $}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Compact 2$\times $3 $\alpha $-sweep: rows $=$ \{Mendelian, Complex\}, columns $=$ three diagnostics. \textbf  {(a)} Calibration residual $\mathrm  {cov} - (1{-}\alpha )$ for Split CP (homoscedastic class-cond), HCCP class-cond, and HCCP Mondrian $(y \times \hat  {\sigma }\text  {-bin})$; the shaded band is the finite-sample slack $\pm 1/(n_{\qopname  \relax m{min}}{+}1)$. All three methods track target to within the slack on both datasets. \textbf  {(b)} $\hat  {\sigma }$-bin coverage range $\qopname  \relax m{max}_b \mathrm  {cov}_b - \qopname  \relax m{min}_b \mathrm  {cov}_b$ for HCCP Mondrian, vs the dashed $\alpha {=}0.10$ headline threshold ($0.04$); respected at every $\alpha $ on both datasets. \textbf  {(c)} Singleton fraction (the operational knob), with the three benchmarked operating points $\alpha \in \{0.10, 0.20, 0.30\}$ marked by vertical guides — high-stakes / triage / hypothesis (see body text).}}{34}{figure.7}\protected@file@percent }
\newlabel{fig:alpha_sweep}{{7}{34}{Compact 2$\times $3 $\alpha $-sweep: rows $=$ \{Mendelian, Complex\}, columns $=$ three diagnostics. \textbf {(a)} Calibration residual $\mathrm {cov} - (1{-}\alpha )$ for Split CP (homoscedastic class-cond), HCCP class-cond, and HCCP Mondrian $(y \times \shat \text {-bin})$; the shaded band is the finite-sample slack $\pm 1/(n_{\min }{+}1)$. All three methods track target to within the slack on both datasets. \textbf {(b)} $\shat $-bin coverage range $\max _b \mathrm {cov}_b - \min _b \mathrm {cov}_b$ for HCCP Mondrian, vs the dashed $\alpha {=}0.10$ headline threshold ($0.04$); respected at every $\alpha $ on both datasets. \textbf {(c)} Singleton fraction (the operational knob), with the three benchmarked operating points $\alpha \in \{0.10, 0.20, 0.30\}$ marked by vertical guides — high-stakes / triage / hypothesis (see body text)}{figure.7}{}}
