\newlabel{tab:imbsweep}{{11}{25}{Imbalance sweep: $\mathrm {cov}_{|Y=1}$ as a function of $\pi _{+}$, Complex CADD+GPN-MSA+Borzoi. Partition $K$ for B2 / B4 selected per outer fold via nested chrom-LOO at $K_{\mathrm {eval}} = 5$. B1 and B2 collapse as $\pi _{+} \to 0$; B3 and B4 are insensitive}{table.11}{}}
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Paired bootstrap: HCCP $\hat  {\sigma }$-bin gap minus baseline $\hat  {\sigma }$-bin gap, computed on the same $B = 200$ chrom-resamples per replicate (seed $42$, identical to Tab.\nobreakspace  {}\ref  {tab:cp_baselines}). Negative paired mean $\Rightarrow $ HCCP narrower; ``Win\,\%'' is the share of resamples on which HCCP attained a strictly smaller gap; $p_{\mathrm  {one}}$ is the one-sided bootstrap $p$-value (floor $1/(B+1) \approx 0.005$). Complex shows decisive HCCP wins; on Mendelian, HCCP wins the majority of resamples but the paired CI crosses zero, so we cannot reject equivalence with weighted CP at the $95\%$ level.}}{25}{table.12}\protected@file@percent }
\newlabel{tab:paired_bootstrap}{{12}{25}{Paired bootstrap: HCCP $\shat $-bin gap minus baseline $\shat $-bin gap, computed on the same $B = 200$ chrom-resamples per replicate (seed $42$, identical to Tab.~\ref {tab:cp_baselines}). Negative paired mean $\Rightarrow $ HCCP narrower; ``Win\,\%'' is the share of resamples on which HCCP attained a strictly smaller gap; $p_{\mathrm {one}}$ is the one-sided bootstrap $p$-value (floor $1/(B+1) \approx 0.005$). Complex shows decisive HCCP wins; on Mendelian, HCCP wins the majority of resamples but the paired CI crosses zero, so we cannot reject equivalence with weighted CP at the $95\%$ level}{table.12}{}}
