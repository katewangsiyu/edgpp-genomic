\@writefile{lot}{\contentsline {table}{\numberline {15}{\ignorespaces $K_{\mathrm  {eval}}$ sensitivity (single-seed point estimates). The recommended $K_{\mathrm  {eval}}$ (Mendelian $K_{\mathrm  {eval}} = 3$, Complex $K_{\mathrm  {eval}} = 5$) keeps $\geq 100$ minority-class samples per cell. \textbf  {Complex}: HCCP dominates by $25$–$34\times $ at $K_{\mathrm  {eval}} \leq 5$ and by $3$–$4\times $ at $K_{\mathrm  {eval}} \geq 8$, robustly across the sweep. \textbf  {Mendelian}: HCCP wins by $1.15\times $ at the recommended $K_{\mathrm  {eval}} = 3$ and ties at $K_{\mathrm  {eval}} = 2$; at $K_{\mathrm  {eval}} \geq 5$, the per-cell minority count drops below $\sim 70$ and weighted CP / RLCP catch up because the heteroscedastic head can no longer be reliably calibrated on the smaller per-cell partition. The Mendelian-specific narrowing of margin at high $K_{\mathrm  {eval}}$ is consistent with the per-cell sample-size floor argument that motivates the recommended $K_{\mathrm  {eval}}$ in the first place (§\ref  {sec:theory:t5}).}}{27}{table.15}\protected@file@percent }
\newlabel{tab:keval_sensitivity}{{15}{27}{$K_{\mathrm {eval}}$ sensitivity (single-seed point estimates). The recommended $K_{\mathrm {eval}}$ (Mendelian $K_{\mathrm {eval}} = 3$, Complex $K_{\mathrm {eval}} = 5$) keeps $\geq 100$ minority-class samples per cell. \textbf {Complex}: HCCP dominates by $25$–$34\times $ at $K_{\mathrm {eval}} \leq 5$ and by $3$–$4\times $ at $K_{\mathrm {eval}} \geq 8$, robustly across the sweep. \textbf {Mendelian}: HCCP wins by $1.15\times $ at the recommended $K_{\mathrm {eval}} = 3$ and ties at $K_{\mathrm {eval}} = 2$; at $K_{\mathrm {eval}} \geq 5$, the per-cell minority count drops below $\sim 70$ and weighted CP / RLCP catch up because the heteroscedastic head can no longer be reliably calibrated on the smaller per-cell partition. The Mendelian-specific narrowing of margin at high $K_{\mathrm {eval}}$ is consistent with the per-cell sample-size floor argument that motivates the recommended $K_{\mathrm {eval}}$ in the first place (§\ref {sec:theory:t5})}{table.15}{}}
\@writefile{lot}{\contentsline {table}{\numberline {16}{\ignorespaces Per-chromosome coverage under Mondrian-$(y \times \hat  {\sigma }\text  {-bin})$, Mendelian dataset. Target: 0.90. Chromosomes 17--22, X are test chroms under chrom-LOO. Worst per-chrom $|\mathrm  {gap}| = 0.100$ at chr6 (cov $0.800$); the second-worst is chr19 ($|\mathrm  {gap}| = 0.073$). The cell-level KS audit (Tab.\nobreakspace  {}\ref  {tab:ks_audit}) shows that this cross-chromosome variability is dataset-intrinsic on Mendelian; T3$'$ supplies the certificate (App.\nobreakspace  {}\ref  {app:proofs:t3prime}).}}{27}{table.16}\protected@file@percent }
\newlabel{tab:perchrom}{{16}{27}{Per-chromosome coverage under Mondrian-$(y \times \shat \text {-bin})$, Mendelian dataset. Target: 0.90. Chromosomes 17--22, X are test chroms under chrom-LOO. Worst per-chrom $|\mathrm {gap}| = 0.100$ at chr6 (cov $0.800$); the second-worst is chr19 ($|\mathrm {gap}| = 0.073$). The cell-level KS audit (Tab.~\ref {tab:ks_audit}) shows that this cross-chromosome variability is dataset-intrinsic on Mendelian; T3$'$ supplies the certificate (App.~\ref {app:proofs:t3prime})}{table.16}{}}
