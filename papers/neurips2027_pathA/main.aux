\@writefile{lot}{\contentsline {table}{\numberline {13}{\ignorespaces Methods that meet $(\mathrm  {cov}_{|Y=1} \geq T_1,\ \hat  {\sigma }\text  {-bin gap} \leq T_2)$ at the recommended $K_{\mathrm  {eval}}$, across a $T_1 \times T_2$ grid. ``H'' = HCCP only; ``H, $X$, \dots  '' = HCCP plus other methods also pass; ``---'' = no method passes (the ceiling is below HCCP's own performance). Complex: HCCP is uniquely Pareto-frontier across the entire reasonable grid (gap separation $0.060$ vs.\ $\geq 0.805$ is order-of-magnitude). Mendelian: HCCP is uniquely Pareto-frontier in a $2 \times 2$ window around the paper's $(0.85, 0.20)$ choice; $T_2 \geq 0.30$ lets B1 (gap $0.265$) and wCP (gap $0.252$) through, and $T_1 \geq 0.90$ or $T_2 \leq 0.15$ excludes HCCP itself --- the operating window is narrow but the choice is not at the boundary.}}{26}{table.13}\protected@file@percent }
\newlabel{tab:threshold_sensitivity}{{13}{26}{Methods that meet $(\mathrm {cov}_{|Y=1} \geq T_1,\ \shat \text {-bin gap} \leq T_2)$ at the recommended $K_{\mathrm {eval}}$, across a $T_1 \times T_2$ grid. ``H'' = HCCP only; ``H, $X$, \dots '' = HCCP plus other methods also pass; ``---'' = no method passes (the ceiling is below HCCP's own performance). Complex: HCCP is uniquely Pareto-frontier across the entire reasonable grid (gap separation $0.060$ vs.\ $\geq 0.805$ is order-of-magnitude). Mendelian: HCCP is uniquely Pareto-frontier in a $2 \times 2$ window around the paper's $(0.85, 0.20)$ choice; $T_2 \geq 0.30$ lets B1 (gap $0.265$) and wCP (gap $0.252$) through, and $T_1 \geq 0.90$ or $T_2 \leq 0.15$ excludes HCCP itself --- the operating window is narrow but the choice is not at the boundary}{table.13}{}}
