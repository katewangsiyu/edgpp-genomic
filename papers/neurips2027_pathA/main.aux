\@writefile{lot}{\contentsline {table}{\numberline {21}{\ignorespaces Four $L_F$ estimators and their oracle $K^\star = \lfloor \sqrt  {L_F R \pi _{\qopname  \relax m{min}} n}\rfloor $ and $G(K^\star ) \leq 2\sqrt  {L_F R / (\pi _{\qopname  \relax m{min}} n)}$ bounds. CIs are 95\% bootstrap percentile intervals over $B = 500$ chrom-level resamples. The modal nested-CV $\hat  K(c_{\mathrm  {outer}})$ (§\ref  {sec:theory:t5}) is reported for comparison; the legacy non-nested $K_{\mathrm  {CV}}$ (test-gap argmin) values $3$ Mendelian and $2$ Complex are deprecated. $^\dagger $On Complex, the full-data legacy point estimate $53.3$ lies just below CI lower bound: under bootstrap resampling the legacy max-of-ratios is consistently larger (median $72.1$, mean $73.8$), reflecting its instability under repeated extreme-pair concentration.}}{31}{table.21}\protected@file@percent }
\newlabel{tab:LF_estimators}{{21}{31}{Four $L_F$ estimators and their oracle $K^\star = \lfloor \sqrt {L_F R \pi _{\min } n}\rfloor $ and $G(K^\star ) \leq 2\sqrt {L_F R / (\pi _{\min } n)}$ bounds. CIs are 95\% bootstrap percentile intervals over $B = 500$ chrom-level resamples. The modal nested-CV $\hat K(c_{\mathrm {outer}})$ (§\ref {sec:theory:t5}) is reported for comparison; the legacy non-nested $K_{\mathrm {CV}}$ (test-gap argmin) values $3$ Mendelian and $2$ Complex are deprecated. $^\dagger $On Complex, the full-data legacy point estimate $53.3$ lies just below CI lower bound: under bootstrap resampling the legacy max-of-ratios is consistently larger (median $72.1$, mean $73.8$), reflecting its instability under repeated extreme-pair concentration}{table.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Joint bootstrap robustness of HCCP on the (Cov$|Y{=}1$, $\hat  {\sigma }$-bin gap) plane (the same axes as Fig.\nobreakspace  {}\ref  {fig:concept}(b)): $B = 200$ chromosome-level resamples at $K = 5$, $\alpha = 0.10$. Each panel shows replicate scatter (red points), 50\% / 95\% Gaussian-KDE contours, the bootstrap mean (\textbf  {+}), and the single-seed all-chrom point estimate ($\bigstar $, blue). Marginal KDEs sit on the top and right axes; dashed lines mark the all-chrom point on each marginal. \textbf  {Mendelian} (left): bootstrap 95\% CIs Cov$|Y{=}1 \in [0.858, 0.918]$, $\hat  {\sigma }$-bin gap $\in [0.004, 0.044]$; the all-chrom point $(0.905, 0.005)$ lies inside the 50\% contour. The wider cloud reflects chrom-level heterogeneity (Fig.\nobreakspace  {}\ref  {fig:per_chrom}). \textbf  {Complex} (right): $\mathrm  {Cov}|Y{=}1 \in [0.894, 0.911]$, gap $\in [0.002, 0.006]$; the all-chrom point $(0.908, 0.002)$ sits at the cloud centre. On both datasets the bootstrap CIs lie strictly inside the (Cov$|Y{=}1 \geq 0.85$, gap $\leq 0.20$) ideal corner of Fig.\nobreakspace  {}\ref  {fig:concept}(b), demonstrating that the headline frontier-point claim is not driven by a single favourable chromosome split.}}{31}{figure.4}\protected@file@percent }
\newlabel{fig:bootstrap_density}{{4}{31}{Joint bootstrap robustness of HCCP on the (Cov$|Y{=}1$, $\shat $-bin gap) plane (the same axes as Fig.~\ref {fig:concept}(b)): $B = 200$ chromosome-level resamples at $K = 5$, $\alpha = 0.10$. Each panel shows replicate scatter (red points), 50\% / 95\% Gaussian-KDE contours, the bootstrap mean (\textbf {+}), and the single-seed all-chrom point estimate ($\bigstar $, blue). Marginal KDEs sit on the top and right axes; dashed lines mark the all-chrom point on each marginal. \textbf {Mendelian} (left): bootstrap 95\% CIs Cov$|Y{=}1 \in [0.858, 0.918]$, $\shat $-bin gap $\in [0.004, 0.044]$; the all-chrom point $(0.905, 0.005)$ lies inside the 50\% contour. The wider cloud reflects chrom-level heterogeneity (Fig.~\ref {fig:per_chrom}). \textbf {Complex} (right): $\mathrm {Cov}|Y{=}1 \in [0.894, 0.911]$, gap $\in [0.002, 0.006]$; the all-chrom point $(0.908, 0.002)$ sits at the cloud centre. On both datasets the bootstrap CIs lie strictly inside the (Cov$|Y{=}1 \geq 0.85$, gap $\leq 0.20$) ideal corner of Fig.~\ref {fig:concept}(b), demonstrating that the headline frontier-point claim is not driven by a single favourable chromosome split}{figure.4}{}}
