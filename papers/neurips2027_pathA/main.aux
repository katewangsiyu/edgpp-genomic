\@writefile{lot}{\contentsline {table}{\numberline {16}{\ignorespaces Four $L_F$ estimators and their oracle $K^\star = \lfloor \sqrt  {L_F R \pi _{\qopname  \relax m{min}} n}\rfloor $ and $G(K^\star ) \leq 2\sqrt  {L_F R / (\pi _{\qopname  \relax m{min}} n)}$ bounds. The cross-validated $\hat  K_{\mathrm  {CV}}$ is reported for comparison.}}{36}{table.16}\protected@file@percent }
\newlabel{tab:LF_estimators}{{16}{36}{Four $L_F$ estimators and their oracle $K^\star = \lfloor \sqrt {L_F R \pi _{\min } n}\rfloor $ and $G(K^\star ) \leq 2\sqrt {L_F R / (\pi _{\min } n)}$ bounds. The cross-validated $\hat K_{\mathrm {CV}}$ is reported for comparison}{table.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces $L_F$ estimator 95\% bootstrap CIs and resulting $K^\star $. LCLS gives a tight CI ($\hat  L_F \approx 3$ Mendelian, $\approx 4.5$ Complex) and a realisable $K^\star $ (22 / 50). Isotonic envelope is loose. Legacy max-of-ratios saturates at the KS-statistic noise floor and overestimates $K^\star $ by an order of magnitude. The cross-validated $\hat  K_{\mathrm  {CV}} \in \{2, 3\}$ is the binding finite-sample constraint, well below all three asymptotic $K^\star $ predictions.}}{36}{figure.9}\protected@file@percent }
\newlabel{fig:lf_forest}{{9}{36}{$L_F$ estimator 95\% bootstrap CIs and resulting $K^\star $. LCLS gives a tight CI ($\hat L_F \approx 3$ Mendelian, $\approx 4.5$ Complex) and a realisable $K^\star $ (22 / 50). Isotonic envelope is loose. Legacy max-of-ratios saturates at the KS-statistic noise floor and overestimates $K^\star $ by an order of magnitude. The cross-validated $\hat K_{\mathrm {CV}} \in \{2, 3\}$ is the binding finite-sample constraint, well below all three asymptotic $K^\star $ predictions}{figure.9}{}}
