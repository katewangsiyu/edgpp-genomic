\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Wall-clock cost of the full HCCP pipeline and main baselines, single chrom-LOO sweep on TraitGym. CPU times on 16-core Xeon; GPU on a single T4. Memory peak excludes Python overhead. $\hat  {p}$ training is per feature set; $\hat  {\sigma }$ training is on chrom-LOO OOF residuals; Mondrian calibration is reported per $K$. DEGU-lite shares the $\hat  {p}$ backbone. The $B = 200$ chromosome-level bootstrap (Tab.\nobreakspace  {}\ref  {tab:main}) reuses cached calibration scores and adds $\sim 30$ CPU-min total.}}{23}{table.7}\protected@file@percent }
\newlabel{tab:compute}{{7}{23}{Wall-clock cost of the full HCCP pipeline and main baselines, single chrom-LOO sweep on TraitGym. CPU times on 16-core Xeon; GPU on a single T4. Memory peak excludes Python overhead. $\phat $ training is per feature set; $\shat $ training is on chrom-LOO OOF residuals; Mondrian calibration is reported per $K$. DEGU-lite shares the $\phat $ backbone. The $B = 200$ chromosome-level bootstrap (Tab.~\ref {tab:main}) reuses cached calibration scores and adds $\sim 30$ CPU-min total}{table.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces HCCP vs.\ closest / concurrent CP work, by guarantee axis. $\text  {$\mathsurround \z@ \mathchar "458$}$ = method explicitly addresses the axis with a finite-sample guarantee; $\circ $ = handled but without a finite-sample bound, or on a different axis (e.g., RLCP: kernel localisation in feature space, not the $\hat  {\sigma }$ axis); $\times $ = not addressed. ``Lower bound'' refers to a matching within-class minimax lower bound that pairs with the upper-bound rate; Yao 2026 / xie 2025 do not provide one for their respective rates. ``Data-dep.\ partition'' refers to a Mondrian-style partition computed from data; class-conditional CP \citep  {sadinle2019lac} and Boström 2020 use pre-specified groups (label / $\hat  {\sigma }$-quantile bins fixed before calibration). \citet  {bairaktari2025kandinsky} subsume class-conditional and Mondrian as static-group special cases but require pre-specified groups, hence $\times $ on the partition column. SC-CP \citep  {vanderlaan2024sccp} uses an isotonic recalibration on the $\hat  \mu $ axis (different from $\hat  {\sigma }$).}}{23}{table.8}\protected@file@percent }
\newlabel{tab:subsumption}{{8}{23}{HCCP vs.\ closest / concurrent CP work, by guarantee axis. $\checkmark $ = method explicitly addresses the axis with a finite-sample guarantee; $\circ $ = handled but without a finite-sample bound, or on a different axis (e.g., RLCP: kernel localisation in feature space, not the $\shat $ axis); $\times $ = not addressed. ``Lower bound'' refers to a matching within-class minimax lower bound that pairs with the upper-bound rate; Yao 2026 / xie 2025 do not provide one for their respective rates. ``Data-dep.\ partition'' refers to a Mondrian-style partition computed from data; class-conditional CP \citep {sadinle2019lac} and Boström 2020 use pre-specified groups (label / $\shat $-quantile bins fixed before calibration). \citet {bairaktari2025kandinsky} subsume class-conditional and Mondrian as static-group special cases but require pre-specified groups, hence $\times $ on the partition column. SC-CP \citep {vanderlaan2024sccp} uses an isotonic recalibration on the $\hat \mu $ axis (different from $\shat $)}{table.8}{}}
