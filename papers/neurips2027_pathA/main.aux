\@writefile{lot}{\contentsline {table}{\numberline {17}{\ignorespaces Per-cluster HCCP coverage on the 28 Complex traits with $\geq 10$ positives (trait-LOO, CADD+GPN-MSA+Borzoi, $\alpha = 0.10$, $K = 2$). All three clusters hold target marginal coverage to within $\pm 0.005$ and minority-class coverage to within $\pm 0.04$; the per-trait worst gap stays $\leq 0.043$ in each cluster, confirming that the trait-LOO floor in the headline is not driven by one easy cluster.}}{29}{table.17}\protected@file@percent }
\newlabel{tab:trait_cluster}{{17}{29}{Per-cluster HCCP coverage on the 28 Complex traits with $\geq 10$ positives (trait-LOO, CADD+GPN-MSA+Borzoi, $\alpha = 0.10$, $K = 2$). All three clusters hold target marginal coverage to within $\pm 0.005$ and minority-class coverage to within $\pm 0.04$; the per-trait worst gap stays $\leq 0.043$ in each cluster, confirming that the trait-LOO floor in the headline is not driven by one easy cluster}{table.17}{}}
\@writefile{lot}{\contentsline {table}{\numberline {18}{\ignorespaces Per-cluster HCCP coverage on the 30 Mendelian OMIMs with $\geq 5$ positives (trait-LOO, CADD+GPN-MSA+Borzoi, $\alpha = 0.10$, $K = 3$). Skeletal/connective shows the highest worst per-trait gap ($0.122$) driven by under-coverage of the minority pathogenic class ($\mathrm  {cov}_{|Y=1} = 0.745$); the smaller $n_{\mathrm  {tot}}$ in this cluster ($n = 470$) means per-cell calibration size approaches the $\lceil 1/\alpha \rceil = 10$ floor, where T3's bound widens. The other two clusters hold target tightly.}}{29}{table.18}\protected@file@percent }
\newlabel{tab:omim_cluster}{{18}{29}{Per-cluster HCCP coverage on the 30 Mendelian OMIMs with $\geq 5$ positives (trait-LOO, CADD+GPN-MSA+Borzoi, $\alpha = 0.10$, $K = 3$). Skeletal/connective shows the highest worst per-trait gap ($0.122$) driven by under-coverage of the minority pathogenic class ($\mathrm {cov}_{|Y=1} = 0.745$); the smaller $n_{\mathrm {tot}}$ in this cluster ($n = 470$) means per-cell calibration size approaches the $\lceil 1/\alpha \rceil = 10$ floor, where T3's bound widens. The other two clusters hold target tightly}{table.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Three $L_F$ estimators paired with their implied asymptotic $K^\star $, with the empirical modal nested-CV $\hat  K(c_{\mathrm  {outer}})$ overlaid as the operative reference. \textbf  {Left:} forest of $\hat  L_F$ on log scale, 95\% bootstrap CIs ($B = 500$ chrom-resamples); marker size encodes precision ($1/\qopname  \relax o{log}_{10}$ of CI ratio). LCLS yields a tight CI ($1.19\times $ on Mendelian, $1.05\times $ on Complex); isotonic envelope is order-of-magnitude wider; legacy max-of-ratios sits at the KS-statistic noise floor. \textbf  {Right:} horizontal bar of the implied oracle $K^\star = \lfloor \sqrt  {L_F R \pi _{\qopname  \relax m{min}} n}\rfloor $ (linear axis); the red dashed band/line marks the modal nested-CV $\hat  K(c_{\mathrm  {outer}}) \in \{5, 8\}$ (Mendelian) and $= 5$ (Complex) per §\ref  {sec:theory:t5}. \textbf  {Punchline:} every asymptotic $K^\star $ exceeds $\hat  K_{\mathrm  {modal}}$ by $3\text  {--}10\times $ on the trustworthy LCLS estimator and by orders of magnitude on the loose ones, identifying the App\nobreakspace  {}\ref  {app:tables:ksweep} fallback-dominated regime as the binding finite-sample constraint at $n \leq 11{,}400$. On Complex, the legacy marker uses bootstrap median $72.1$ rather than the unstable full-data point $53.3$ (see Tab.\nobreakspace  {}\ref  {tab:LF_estimators} footnote).}}{29}{figure.3}\protected@file@percent }
\newlabel{fig:lf_forest}{{3}{29}{Three $L_F$ estimators paired with their implied asymptotic $K^\star $, with the empirical modal nested-CV $\hat K(c_{\mathrm {outer}})$ overlaid as the operative reference. \textbf {Left:} forest of $\hat L_F$ on log scale, 95\% bootstrap CIs ($B = 500$ chrom-resamples); marker size encodes precision ($1/\log _{10}$ of CI ratio). LCLS yields a tight CI ($1.19\times $ on Mendelian, $1.05\times $ on Complex); isotonic envelope is order-of-magnitude wider; legacy max-of-ratios sits at the KS-statistic noise floor. \textbf {Right:} horizontal bar of the implied oracle $K^\star = \lfloor \sqrt {L_F R \pi _{\min } n}\rfloor $ (linear axis); the red dashed band/line marks the modal nested-CV $\hat K(c_{\mathrm {outer}}) \in \{5, 8\}$ (Mendelian) and $= 5$ (Complex) per §\ref {sec:theory:t5}. \textbf {Punchline:} every asymptotic $K^\star $ exceeds $\hat K_{\mathrm {modal}}$ by $3\text {--}10\times $ on the trustworthy LCLS estimator and by orders of magnitude on the loose ones, identifying the App~\ref {app:tables:ksweep} fallback-dominated regime as the binding finite-sample constraint at $n \leq 11{,}400$. On Complex, the legacy marker uses bootstrap median $72.1$ rather than the unstable full-data point $53.3$ (see Tab.~\ref {tab:LF_estimators} footnote)}{figure.3}{}}
