\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Per-chromosome HCCP marginal coverage on chrom-LOO ($\alpha = 0.10$, $K = 5$, target $= 0.90$). \textbf  {Mendelian (left)} shows substantial cross-chromosome variability driven by clustering of pathogenic variants: chr6, chr19, and chr9 under-cover (worst chr6 at $0.800$, $|\mathrm  {gap}| = 0.100$); chrX, chr3, chr11 over-cover. The variability is consistent with the high cell-level KS rejection rate on Mendelian (App.\nobreakspace  {}\ref  {app:proofs}) and motivates T3$'$'s robust certificate (Thm.\nobreakspace  {}\ref  {thm:t3prime_main}) over T3's exact bin-conditional bound. \textbf  {Complex (right)} is tighter — all chromosomes within $\pm 0.04$ of target — reflecting Complex's lower cross-chromosome heterogeneity.}}{24}{figure.2}\protected@file@percent }
\newlabel{fig:per_chrom}{{2}{24}{Per-chromosome HCCP marginal coverage on chrom-LOO ($\alpha = 0.10$, $K = 5$, target $= 0.90$). \textbf {Mendelian (left)} shows substantial cross-chromosome variability driven by clustering of pathogenic variants: chr6, chr19, and chr9 under-cover (worst chr6 at $0.800$, $|\mathrm {gap}| = 0.100$); chrX, chr3, chr11 over-cover. The variability is consistent with the high cell-level KS rejection rate on Mendelian (App.~\ref {app:proofs}) and motivates T3$'$'s robust certificate (Thm.~\ref {thm:t3prime_main}) over T3's exact bin-conditional bound. \textbf {Complex (right)} is tighter — all chromosomes within $\pm 0.04$ of target — reflecting Complex's lower cross-chromosome heterogeneity}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {C.5}Per-trait clinical clustering (Complex traits)}{24}{subsection.C.5}\protected@file@percent }
\newlabel{app:tables:trait_cluster}{{C.5}{24}{Per-trait clinical clustering (Complex traits)}{subsection.C.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces $K_{\mathrm  {eval}}$ sensitivity (single-seed point estimates). The recommended $K_{\mathrm  {eval}}$ (Mendelian $K_{\mathrm  {eval}} = 3$, Complex $K_{\mathrm  {eval}} = 5$) keeps $\geq 100$ minority-class samples per cell. \textbf  {Complex}: HCCP dominates by $25$–$34\times $ at $K_{\mathrm  {eval}} \leq 5$ and by $3$–$4\times $ at $K_{\mathrm  {eval}} \geq 8$, robustly across the sweep. \textbf  {Mendelian}: HCCP wins by $1.15\times $ at the recommended $K_{\mathrm  {eval}} = 3$ and ties at $K_{\mathrm  {eval}} = 2$; at $K_{\mathrm  {eval}} \geq 5$, the per-cell minority count drops below $\sim 70$ and weighted CP / RLCP catch up because the heteroscedastic head can no longer be reliably calibrated on the smaller per-cell partition. The Mendelian-specific narrowing of margin at high $K_{\mathrm  {eval}}$ is consistent with the per-cell sample-size floor argument that motivates the recommended $K_{\mathrm  {eval}}$ in the first place (§\ref  {sec:theory:t5}).}}{25}{table.12}\protected@file@percent }
\newlabel{tab:keval_sensitivity}{{12}{25}{$K_{\mathrm {eval}}$ sensitivity (single-seed point estimates). The recommended $K_{\mathrm {eval}}$ (Mendelian $K_{\mathrm {eval}} = 3$, Complex $K_{\mathrm {eval}} = 5$) keeps $\geq 100$ minority-class samples per cell. \textbf {Complex}: HCCP dominates by $25$–$34\times $ at $K_{\mathrm {eval}} \leq 5$ and by $3$–$4\times $ at $K_{\mathrm {eval}} \geq 8$, robustly across the sweep. \textbf {Mendelian}: HCCP wins by $1.15\times $ at the recommended $K_{\mathrm {eval}} = 3$ and ties at $K_{\mathrm {eval}} = 2$; at $K_{\mathrm {eval}} \geq 5$, the per-cell minority count drops below $\sim 70$ and weighted CP / RLCP catch up because the heteroscedastic head can no longer be reliably calibrated on the smaller per-cell partition. The Mendelian-specific narrowing of margin at high $K_{\mathrm {eval}}$ is consistent with the per-cell sample-size floor argument that motivates the recommended $K_{\mathrm {eval}}$ in the first place (§\ref {sec:theory:t5})}{table.12}{}}
\@writefile{lot}{\contentsline {table}{\numberline {13}{\ignorespaces Per-chromosome coverage under Mondrian-$(y \times \hat  {\sigma }\text  {-bin})$, Mendelian dataset. Target: 0.90. Chromosomes 17--22, X are test chroms under chrom-LOO. Worst per-chrom $|\mathrm  {gap}| = 0.100$ at chr6 (cov $0.800$); the second-worst is chr19 ($|\mathrm  {gap}| = 0.073$). The cell-level KS audit (Tab.\nobreakspace  {}\ref  {tab:ks_audit}) shows that this cross-chromosome variability is dataset-intrinsic on Mendelian; T3$'$ supplies the certificate (App.\nobreakspace  {}\ref  {app:proofs:t3prime}).}}{25}{table.13}\protected@file@percent }
\newlabel{tab:perchrom}{{13}{25}{Per-chromosome coverage under Mondrian-$(y \times \shat \text {-bin})$, Mendelian dataset. Target: 0.90. Chromosomes 17--22, X are test chroms under chrom-LOO. Worst per-chrom $|\mathrm {gap}| = 0.100$ at chr6 (cov $0.800$); the second-worst is chr19 ($|\mathrm {gap}| = 0.073$). The cell-level KS audit (Tab.~\ref {tab:ks_audit}) shows that this cross-chromosome variability is dataset-intrinsic on Mendelian; T3$'$ supplies the certificate (App.~\ref {app:proofs:t3prime})}{table.13}{}}
